<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Assets/Scripts/Domain/Defs（ロードされた定義: UnmappedIsland.Domain.Defs名前空間）と
    Assets/Scripts/Domain/Runtime（可変な実行時状態: UnmappedIsland.Domain.Runtime名前空間。tick=15分等、
    core.yamlの内容に依存するこのゲーム固有の時間進行ロジックもここに含む）配下のコードは
    UnityEngineに依存しない純粋なC#であるため、Unityエディタなしでもビルド・テストできるよう、
    実体のソースをそのまま参照するスタンドアロンのクラスライブラリとして定義する
    （ファイルの複製はしない）。LangVersionはUnity 2022.3のRoslynが受け付ける範囲に揃えてある。
  -->

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <LangVersion>9.0</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="../../Assets/Scripts/Domain/Defs/**/*.cs" />
    <Compile Include="../../Assets/Scripts/Domain/Runtime/**/*.cs" />
    <Compile Include="../../Assets/Scripts/Domain/Generation/**/*.cs" />
    <Compile Include="../../Assets/Scripts/Loader/**/*.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="YamlDotNet" Version="18.1.0" />
  </ItemGroup>

</Project>
